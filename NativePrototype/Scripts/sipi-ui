#!/usr/bin/env bash
#
# sipi-ui — AXe-first UI driver with automatic native fallback.
#
# Uses AXe (fast, label-addressable) by default and transparently falls back to
# the native bridge (sipi-bridge) ONLY when AXe can't see/act on the target —
# i.e. when a System UI layer (PhotosPicker, Share Sheet, SFSafariViewController,
# ASWebAuthenticationSession, status bar, cross-process overlays) is up, which
# AXe reports as "app root only" / "no accessibility element matched".
#
# Usage:
#   sipi-ui describe <udid>                  # AXe; auto-falls back to native ax for System UI
#   sipi-ui describe <udid> --expect "text"  # native fallback when AXe misses expected text
#   SIPI_UI_FORCE_NATIVE=1 sipi-ui describe <udid>
#   sipi-ui tap <udid> --label "<label>"     # AXe; native fallback by frame on miss
#   sipi-ui tap <udid> --id "<identifier>"   # AXe; native fallback by frame on miss
#   sipi-ui tap <udid> -x <x> -y <y>         # passthrough to AXe (raw coordinate)
#
# Requires: `axe` on PATH; `sipi-bridge` (set $SIPI_BRIDGE or built at ../.build/debug).
set -uo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"
BRIDGE="${SIPI_BRIDGE:-$HERE/../.build/debug/sipi-bridge}"
log() { echo "[sipi-ui] $*" >&2; }

require_axe() {
  if ! command -v axe >/dev/null 2>&1; then
    log "axe is required; install it and run axe init"
    exit 127
  fi
}

require_bridge() {
  if [ ! -x "$BRIDGE" ]; then
    log "native bridge not executable: $BRIDGE"
    log "run 'swift build' in NativePrototype or set SIPI_BRIDGE"
    exit 127
  fi
}

count_nodes() {
  python3 -c '
import sys, json
try: d = json.load(sys.stdin)
except Exception: print(0); sys.exit()
c = [0]
def w(x):
    if isinstance(x, dict):
        c[0] += 1
        for v in x.values():
            if isinstance(v, list):
                for e in v: w(e)
    elif isinstance(x, list):
        for e in x: w(e)
w(d); print(c[0])'
}

cmd="${1:-}"; shift || true
case "$cmd" in
  describe)
    require_axe
    udid="${1:?udid required}"
    shift || true
    expect="${SIPI_UI_EXPECT:-}"
    while [ $# -gt 0 ]; do
      case "$1" in
        --expect) [ $# -ge 2 ] || { log "--expect requires a value"; exit 2; }; expect="$2"; shift 2;;
        --native) export SIPI_UI_FORCE_NATIVE=1; shift;;
        *) shift;;
      esac
    done
    if [ "${SIPI_UI_FORCE_NATIVE:-0}" = "1" ]; then
      require_bridge
      log "using native bridge (forced)"
      "$BRIDGE" ax "$udid"
      exit $?
    fi
    axout="$(axe describe-ui --udid "$udid" 2>/dev/null || true)"
    n="$(printf '%s' "$axout" | count_nodes)"
    min_nodes="${SIPI_UI_MIN_AXE_NODES:-3}"
    if [ "${n:-0}" -le "$min_nodes" ]; then
      require_bridge
      log "AXe saw only ${n} node(s) — System UI likely; using native bridge"
      "$BRIDGE" ax "$udid"
    elif [ -n "$expect" ] && ! printf '%s' "$axout" | grep -Fq "$expect"; then
      require_bridge
      log "AXe (${n} nodes) missed expected text '${expect}' — trying native bridge"
      "$BRIDGE" ax "$udid"
    elif printf '%s' "$axout" | grep -Eq 'DockFolderViewService|AXLabel" : "SpringBoard"|AXLabel" : "Simulator"'; then
      require_bridge
      log "AXe appears to be on a simulator/system shell — using native bridge"
      "$BRIDGE" ax "$udid"
    else
      log "AXe (${n} nodes)"
      printf '%s\n' "$axout"
    fi
    ;;

  tap)
    require_axe
    udid="${1:?udid required}"; shift || true
    label=""; ident=""; x=""; y=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --label) [ $# -ge 2 ] || { log "--label requires a value"; exit 2; }; label="$2"; shift 2;;
        --id)    [ $# -ge 2 ] || { log "--id requires a value"; exit 2; }; ident="$2"; shift 2;;
        -x)      [ $# -ge 2 ] || { log "-x requires a value"; exit 2; }; x="$2"; shift 2;;
        -y)      [ $# -ge 2 ] || { log "-y requires a value"; exit 2; }; y="$2"; shift 2;;
        *)       shift;;
      esac
    done

    if [ -n "$x" ] && [ -n "$y" ]; then
      exec axe tap -x "$x" -y "$y" --udid "$udid"
    fi

    if [ -n "$label" ]; then
      out="$(axe tap --label "$label" --udid "$udid" 2>&1)"
      status=$?
      field="AXLabel"; key="$label"
    elif [ -n "$ident" ]; then
      out="$(axe tap --id "$ident" --udid "$udid" 2>&1)"
      status=$?
      field="AXUniqueId"; key="$ident"
    else
      log "tap requires --label, --id, or both -x and -y"
      exit 2
    fi

    if [ "$status" -eq 0 ]; then
      printf '%s\n' "$out"   # AXe handled it
      exit 0
    fi
    if ! printf '%s' "$out" | grep -q "No accessibility element matched"; then
      printf '%s\n' "$out" >&2
      exit "$status"
    fi

    require_bridge
    log "AXe can't find '${key}' — native fallback (System UI)"
    ax_tmp="$(mktemp "${TMPDIR:-/tmp}/sipi-ui-ax.XXXXXX.json")"
    trap 'rm -f "$ax_tmp"' EXIT
    "$BRIDGE" ax "$udid" > "$ax_tmp"
    coords="$(python3 - "$ax_tmp" "$field" "$key" <<'PY'
import json, sys
path, field, key = sys.argv[1], sys.argv[2], sys.argv[3]
d = json.load(open(path))
root = d[0]['frame']; sw, sh = root['width'], root['height']
hit = [None]
def w(n):
    if isinstance(n, dict):
        if (n.get(field) or '') == key and hit[0] is None: hit[0] = n
        for c in n.get('children', []) or []: w(c)
for r in d: w(r)
if hit[0] is None: sys.exit(3)
f = hit[0]['frame']
print('%.4f %.4f' % ((f['x'] + f['width'] / 2) / sw, (f['y'] + f['height'] / 2) / sh))
PY
)"
    if [ -z "${coords:-}" ]; then
      log "native bridge also couldn't find '${key}'"
      exit 3
    fi
    log "native tap ${coords}"
    exec "$BRIDGE" tap "$udid" $coords
    ;;

  *)
    echo "usage: sipi-ui describe <udid> [--expect TEXT|--native] | tap <udid> (--label L | --id ID | -x X -y Y)" >&2
    exit 2
    ;;
esac
